rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Public read for market and vendor images
    match /markets/{marketId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && firestore.get(/databases/(default)/documents/markets/$(marketId)).data.ownerId == request.auth.uid;
    }

    match /vendors/{vendorId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && firestore.get(/databases/(default)/documents/vendors/$(vendorId)).data.ownerId == request.auth.uid;
    }

    // Authenticated read for everything else
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

  }
}
