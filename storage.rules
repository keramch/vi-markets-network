rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Allow authenticated users to read any file
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Market profile images — any authenticated user can write to markets/{marketId}/
    // (The backend enforces ownership; storage rules just require login)
    match /markets/{marketId}/{fileName} {
      allow write: if request.auth != null
                   && request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Vendor profile images
    match /vendors/{vendorId}/{fileName} {
      allow write: if request.auth != null
                   && request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
